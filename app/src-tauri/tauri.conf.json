{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BLACKOUT",
  "version": "0.1.0",
  "identifier": "com.subh.blackout",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "BLACKOUT",
        "width": 1040,
        "height": 760,
        "minWidth": 880,
        "minHeight": 640,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
